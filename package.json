{
  "name": "port-manager-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/check-package-exports.mjs",
    "build:macos": "swift build --package-path apps/macos",
    "build:raycast": "npm --prefix apps/raycast run build",
    "check": "pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build",
    "lint": "node scripts/check-style.mjs",
    "run:macos": "./script/build_and_run.sh",
    "test": "node --test tests/*.test.js",
    "typecheck": "node scripts/check-syntax.mjs",
    "verify:macos": "./script/build_and_run.sh --verify"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@patrickjs/port-manager": "workspace:*",
    "@patrickjs/port-manager-cli": "workspace:*",
    "@patrickjs/port-manager-compat-detect-port": "workspace:*",
    "@patrickjs/port-manager-compat-get-port": "workspace:*",
    "@patrickjs/port-manager-compat-get-port-please": "workspace:*",
    "@patrickjs/port-manager-compat-portfinder": "workspace:*"
  }
}
